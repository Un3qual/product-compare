{
  "name": "product-compare-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/entry.server.tsx --outDir dist/server",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "relay": "relay-compiler",
    "check": "bun run typecheck && bun run test:unit"
  },
  "dependencies": {
    "@radix-ui/react-direction": "^1.1.1",
    "@stylexjs/stylex": "0.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-relay": "^20.1.1",
    "react-router-dom": "^7.0.0",
    "relay-runtime": "^20.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@stylexjs/babel-plugin": "^0.18.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/relay-runtime": "^20.1.1",
    "@vitejs/plugin-react": "^5.1.0",
    "bun-types": "^1.3.8",
    "jsdom": "^26.1.0",
    "relay-compiler": "^20.1.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
